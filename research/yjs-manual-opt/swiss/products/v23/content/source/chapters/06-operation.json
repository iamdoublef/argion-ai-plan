        {
          "type": "sub_title",
          "text": "6.4 濡備綍浣跨敤鐪熺┖瀵嗗皝鍔熻兘",
          "text_id": "content.chapter.06-operation.page.page3.block.1.text"
        },
        {
          "type": "paragraph",
          "text": "**鐪熺┖瀵嗗皝鍥轰綋鐗╁搧锛?*",
          "text_id": "content.chapter.06-operation.page.page3.block.2.text"
        },
        {
          "type": "step_flow",
          "steps": [
            {
              "id": "step1",
              "text": "灏嗚鍙ｆ斁鍏ョ湡绌鸿厰銆?",
              "text_id": "content.chapter.06-operation.page.page3.block.3.step.step1.text"
            },
            {
              "id": "step2",
              "text": "鍏抽棴闈㈢洊锛屽苟涓嬪帇鎶婃墜浠ラ攣绱ч潰鐩栥€?",
              "text_id": "content.chapter.06-operation.page.page3.block.3.step.step2.text"
            },
            {
              "id": "step3",
              "text": "鐐瑰嚮 [btn:Vac Mode] 鎸夐敭閫夋嫨妯″紡锛?*Normal** 鎴?**Gentle**銆?",
              "text_id": "content.chapter.06-operation.page.page3.block.3.step.step3.text"
            },
            {
              "id": "step4",
              "text": "鐐瑰嚮 [btn:Vac&Seal / Start] 鎸夐敭鍚姩宸ヤ綔銆?",
              "text_id": "content.chapter.06-operation.page.page3.block.3.step.step4.text"
            },
            {
              "id": "step5",
              "text": "鑻ラ渶缁堟宸ヤ綔锛岃鐐瑰嚮 [btn:Stop] 鎸夐敭銆?",
              "text_id": "content.chapter.06-operation.page.page3.block.3.step.step5.text"
            }
          ]
        },
        {
          "type": "notice_box",
          "text": "鍦ㄩ噰鐢?Gentle 妯″紡灏佽璐甸噸鐗╁搧鍓嶏紝寤鸿鍏堥噰鐢ㄥ叾瀹冪墿鍝佸皾璇曠湡绌哄悗鐨勫帇缂╃▼搴︽槸鍚︽弧瓒抽渶姹傦紝浠ュ厤鍘嬬鐗╁搧銆?",
          "text_id": "content.chapter.06-operation.page.page3.block.4.text"
        },
        {
          "type": "paragraph",
          "text": "**鐪熺┖瀵嗗皝娑蹭綋锛?*",
          "text_id": "content.chapter.06-operation.page.page3.block.5.text"
        },
        {
          "type": "split_panel",
          "body_blocks": [
            {
              "type": "step_flow",
              "steps": [
                {
                  "id": "step1",
                  "text": "淇濇寔琚嬪瓙鐩寸珛锛岀‘淇濇恫浣撴恫闈㈠缁堜綆浜庡彂鐑櫒锛屾恫浣撲笌琚嬪彛涔嬮棿寤鸿鐣欏嚭 7 inch锛?8 cm锛夌殑绌洪棿銆?",
                  "text_id": "content.chapter.06-operation.page.page3.block.6.body.1.step.step1.text"
                },
                {
                  "id": "step2",
                  "text": "灏嗚鍙ｆ斁鍏ョ湡绌鸿厰銆?",
                  "text_id": "content.chapter.06-operation.page.page3.block.6.body.1.step.step2.text"
                },
                {
                  "id": "step3",
                  "text": "鍏抽棴闈㈢洊锛屽苟涓嬪帇鎶婃墜浠ラ攣绱ч潰鐩栥€?",
                  "text_id": "content.chapter.06-operation.page.page3.block.6.body.1.step.step3.text"
                },
                {
                  "id": "step4",
                  "text": "鐐瑰嚮 [btn:Vac Mode] 鎸夐敭閫夋嫨 **Liquid** 妯″紡銆?",
                  "text_id": "content.chapter.06-operation.page.page3.block.6.body.1.step.step4.text"
                },
                {
                  "id": "step5",
                  "text": "鐐瑰嚮 [btn:Vac&Seal / Start] 鎸夐敭鍚姩宸ヤ綔銆?",
                  "text_id": "content.chapter.06-operation.page.page3.block.6.body.1.step.step5.text"
                }
              ]
            }
          ],
