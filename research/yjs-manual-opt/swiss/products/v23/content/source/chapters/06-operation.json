        {
          "type": "sub_title",
          "text": "6.6 鐪熺┖杞鐢ㄦ硶",
          "text_id": "content.chapter.06-operation.page.page5.block.1.text"
        },
        {
          "type": "split_panel",
          "body_blocks": [
            {
              "type": "bullet_list",
              "items": [
                {
                  "text": "瀵规妫綈閫傞厤鍣ㄥ拰甯﹂榾闂ㄦ媺閾捐鎶界湡绌烘椂锛屽渾褰㈠惛鍢撮噰鐢ㄦ柟鍚?銆?",
                  "text_id": "content.chapter.06-operation.page.page5.block.2.body.1.item.1"
                },
                {
                  "text": "瀵圭湡绌虹綈鍜岀摱濉炴娊鐪熺┖鏃讹紝鏍规嵁鎶芥皵鍙ｅぇ灏忛€夋嫨鏂瑰悜1鎴?銆?",
                  "text_id": "content.chapter.06-operation.page.page5.block.2.body.1.item.2"
                },
                {
                  "text": "鐪熺┖杞鎵佸舰鍚稿槾3鐢ㄤ簬杩炴帴鏈哄櫒闈㈢洊涓婄殑澶栨娊姘斿彛3銆?",
                  "text_id": "content.chapter.06-operation.page.page5.block.2.body.1.item.3"
                }
              ]
            }
          ],
          "figures": [
            {
              "figure": "06-operation.page03.image04",
              "width": "30mm",
              "height": "auto"
            }
          ]
        },
        {
          "type": "sub_title",
          "text": "6.7 濡備綍鎶芥妫綈",
          "text_id": "content.chapter.06-operation.page.page5.block.3.text"
        },
        {
          "type": "split_panel",
          "body_blocks": [
            {
              "type": "step_flow",
              "steps": [
                {
                  "id": "step1",
                  "text": "闂悎鏈哄櫒闈㈢洊銆?",
                  "text_id": "content.chapter.06-operation.page.page5.block.4.body.1.step.step1.text"
                },
                {
                  "id": "step2",
                  "text": "灏嗙綈鐩栨斁鍒版妫綈缃愬彛锛屼笉闇€鎷т笂铻虹汗鐩栵紙濡傛湁锛夈€?",
                  "text_id": "content.chapter.06-operation.page.page5.block.4.body.1.step.step2.text"
                },
                {
                  "id": "step3",
                  "text": "灏嗛€傞厤鍣ㄥ畨瑁呭埌姊呮．缃愪笂銆?",
                  "text_id": "content.chapter.06-operation.page.page5.block.4.body.1.step.step3.text"
                },
                {
                  "id": "step4",
                  "text": "灏嗙湡绌鸿蒋绠℃墎褰㈠惛鍢存彃鍏ユ満鍣ㄩ潰鐩栦笂鐨勫鎶芥皵瀛斻€?",
                  "text_id": "content.chapter.06-operation.page.page5.block.4.body.1.step.step4.text"
                },
                {
                  "id": "step5",
                  "text": "鍘嬩笅鎶婃墜浠ラ攣绱ч潰鐩栥€?",
                  "text_id": "content.chapter.06-operation.page.page5.block.4.body.1.step.step5.text"
                },
