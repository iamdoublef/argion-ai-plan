                  "id": "step1",
                  "text": "鎵撳紑闈㈢洊銆?",
                  "text_id": "content.chapter.06-operation.page.page1.block.2.body.1.step.step1.text"
                },
                {
                  "id": "step2",
                  "text": "鎵撳紑鍒囪鍒€鏋躲€?",
                  "text_id": "content.chapter.06-operation.page.page1.block.2.body.1.step.step2.text"
                },
                {
                  "id": "step3",
                  "text": "浠庡嵎琚嬩笂鎷夋壇鍑烘墍闇€闀垮害鐨勮瀛愩€?",
                  "text_id": "content.chapter.06-operation.page.page1.block.2.body.1.step.step3.text"
                },
                {
                  "id": "step4",
                  "text": "灏嗗垏琚嬪垁绉昏嚦鏈€宸︽垨鏈€鍙宠竟锛屽啀浣垮垁鏋朵笅鍘嬬潃琚嬪瓙銆?",
                  "text_id": "content.chapter.06-operation.page.page1.block.2.body.1.step.step4.text"
                },
                {
                  "id": "step5",
                  "text": "灏嗗垏琚嬪垁涓嬪帇婊戝姩鍒掕繃琚嬪瓙锛屼互杩涜鏁撮綈鐨勫垏鍓层€?",
                  "text_id": "content.chapter.06-operation.page.page1.block.2.body.1.step.step5.text"
                }
              ]
            }
