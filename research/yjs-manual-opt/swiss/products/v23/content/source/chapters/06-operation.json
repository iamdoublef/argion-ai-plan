          ]
        },
        {
          "type": "sub_title",
          "text": "6.2 濡備綍浣跨敤瀵嗗皝鍔熻兘",
          "text_id": "content.chapter.06-operation.page.page1.block.3.text"
        },
        {
          "type": "paragraph",
          "text": "**浠庡嵎琚嬩腑鍒朵綔琚嬪瓙骞跺瘑灏侊細**",
          "text_id": "content.chapter.06-operation.page.page1.block.4.text"
        },
        {
          "type": "step_flow",
          "steps": [
            {
              "id": "step1",
              "text": "鎸変互涓婂浣曚娇鐢ㄥ垏琚嬪垁鍒朵綔鍑轰竴涓袱绔紑鍙ｇ殑琚嬪瓙銆?",
              "text_id": "content.chapter.06-operation.page.page1.block.5.step.step1.text"
            },
            {
              "id": "step2",
              "text": "灏嗚瀛愮殑涓€绔紑鍙ｅ钩鏁存斁鍏ョ湡绌鸿厰鍐呫€?",
              "text_id": "content.chapter.06-operation.page.page1.block.5.step.step2.text"
            },
            {
              "id": "step3",
              "text": "鍏抽棴闈㈢洊锛屽苟灏嗘妸鎵嬪悜涓嬪帇浠ラ攣绱ч潰鐩栥€?",
              "text_id": "content.chapter.06-operation.page.page1.block.5.step.step3.text"
            },
            {
              "id": "step4",
              "text": "鐐瑰嚮 [btn:Seal] 鎸夐敭锛屽苟绛夊緟鏈哄櫒瀹屾垚宸ヤ綔銆?",
              "text_id": "content.chapter.06-operation.page.page1.block.5.step.step4.text"
            }
          ]
        },
        {
          "type": "paragraph",
          "text": "**鍗曠嫭瀵嗗皝琚嬪瓙锛?*",
          "text_id": "content.chapter.06-operation.page.page1.block.6.text"
        },
        {
          "type": "split_panel",
          "body_blocks": [
            {
              "type": "step_flow",
              "steps": [
                {
                  "id": "step1",
                  "text": "灏嗚瀛愭斁鍏ラ渶瑕佸皝瑁呯殑鐗╁搧锛屽苟灏嗚鍙ｆ斁鍏ョ湡绌鸿厰銆?",
                  "text_id": "content.chapter.06-operation.page.page1.block.7.body.1.step.step1.text"
                },
                {
                  "id": "step2",
                  "text": "鍏抽棴闈㈢洊锛屽苟灏嗘妸鎵嬩笅鍘嬩互閿佺揣闈㈢洊銆?",
                  "text_id": "content.chapter.06-operation.page.page1.block.7.body.1.step.step2.text"
                },
                {
                  "id": "step3",
                  "text": "鐐瑰嚮 [btn:Seal] 鎸夐敭锛屽苟绛夊緟鏈哄櫒瀹屾垚宸ヤ綔銆?",
                  "text_id": "content.chapter.06-operation.page.page1.block.7.body.1.step.step3.text"
                }
              ]
            }
          ],
