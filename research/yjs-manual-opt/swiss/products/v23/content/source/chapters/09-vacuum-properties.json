  "pages": [
    {
      "page_class": "",
      "section_title": "йҗӘзҶәв”–йҚ–е‘°о—Ҡйҗ—и§„вӮ¬?",
      "hide_section_title": false,
      "blocks": [
        {
          "type": "paragraph",
          "text": "йҗӘзҶәв”–йҚ–е‘°о—ҠйҸ„оҲһвӮ¬ж°із№ғйҚҳе©ҡж«ҺзҖөе——зҡқзҖ№з‘°ж«’ж¶“о… ж®‘жҫ¶СҮе„ҙйҚ’е—ҷв”–е§ҳж—ҖжҪөеҜӨе •жҡұжӨӢзҶ·жҗ§йҗЁеӢ«оҮҙйҚӣж–ӨзҙқйӘһе •ж§»е§қгҲўв”–е§ҳж–ҝжҙ–еЁҙдҪёеҹҢзҖөе——зҡқзҖ№з‘°ж«’ж¶“о…Ёзҙқжө еәӨвӮ¬еұҪеҷәзҒҸжҲһе“ҖйҚ–ж ҘвӮ¬еӮңж№Ўз»Ңе“„еҜҳз‘Ғе‘®ж№ҒйҚ”в•Җз°¬ж·ҮжҝҮеҜ”жӨӢеәЎжҮ—йҚңеұҫжҡЈжөЈж’№е·қй–ІеҝӢвӮ¬еӮҡз• жқ©жЁ»ж№ҒйҚ”в•Җз°¬йҺ¶жҲқеҹ—жҝӮиҠҘе“ҖеҜ°оҶҫж•“йҗ—в•ғж®‘йҗўзҶјжҡұй”ӣеұҪж№ӘйҸҢж„Әз°әйҸүвҖІж¬ўж¶“е¬ӘеҪІй‘із•Ңж®‘йҗңжӢҢи–„йҸҲеӨӣзҙ°",
          "text_id": "content.chapter.09-vacuum-properties.page.page1.block.1.text"
        },
        {
          "type": "bullet_list",
          "items": [
            {
              "text": "**й—ҮеӨҺеј»** йҲҘ?й—ҮеӨҺеј»йҚҰг„Өз¶Ҷе§ҳС…е№Ҷжҫ§еҶ§з¬…йҸғзҠізЎ¶з»»дҪ№з•әй”ӣеІҖж№Ўз»Ңе“„еҜҳз‘Ғе‘°е…ҳжҫ¶зҶёе§ӮйҚ’е •ж№Ғй‘ҝеІҖж®‘з»»дҪ№з•әйҠҶ?",
              "text_id": "content.chapter.09-vacuum-properties.page.page1.block.2.item.1"
            },
            {
              "text": "**й–°еһ«зҳқй‘ҝ?* йҲҘ?й–°еһ«зҳқй—ҮвӮ¬з‘•дҪ№жҢүйҠҶдҪәзЎёйҚңеұји…‘з»ӣеӨӢдҝҜжҗҙпёҪеў й‘із•Ңз®’еЁҲж өзҙқйҚҷоҲҷдә’йҚҰг„Ұж№Ғз»ҢзғҳзҡөйҺҙж ЁжЈӨз»ҢзғҳзҡөйҗЁеӢ¬е„ҸйҚҗе…ёз¬…йҗўзҶ·з“ЁйҠҶеӮҡеҷәзјӮж’»еҸәе§Је¶Үж®‘йҗўзҶјжҡұй—ҮвӮ¬з‘•дҪёе–Һй’ҳеҝҘзҙқйҚҗеі°е–•йҚ’ж¬ҸеҪІжө гғҰж№ҒйҸҒе ҹе§ӮйҚ’иәІвӮ¬?",
              "text_id": "content.chapter.09-vacuum-properties.page.page1.block.2.item.2"
            },
            {
              "text": "**зјҒе—ҡеј»** йҲҘ?зҖөиү°еҡ§й—…й№ғжӨҲйҗЁеӢ¬зҡөйҚӣзӮҪвӮ¬дҪёеҪүй‘№еҸүеһЁйҚҷжЁ»з…ҚжқһоҲҳвӮ¬еӮҡж№Әй–«еӮҡз¶ӢйҗЁеӢ¬жҪҜжө жңөз¬…й”ӣеІғеҖқе§ЈжҺ“оқЁй‘ҝеұҪеҪІжө гғҘж№ӘеЁҢв„ғж№Ғз»ҢзғҳзҡөйҗЁеӢ¬е„ҸйҚҗе…ёз¬…йҗўзҶјжҡұй”ӣеұјз¬–йҸғзҠізЎ¶й–«ж°із№ғе§ҳж–ҝжҮ—йҺҙж §жҮ—й–¬ж’ҙо—…еЁҙе¬ӘеҹҢйҠҶ?",
              "text_id": "content.chapter.09-vacuum-properties.page.page1.block.2.item.3"
            }
          ]
        },
        {
          "type": "paragraph",
          "text": "ж¶“еәқжҚўжөЈжӣһеҸҫжө ж §еҒҚзҖӣжЁ»жҹҹеҜ®еҝҺз«ҙйҸҚеҮӨзҙқйҚҰг„©о—Өйҗўг„Ҙеў еҰ«вӮ¬йҸҢгғ©о—ӨйҚқдҪ№ж§ёйҚҡп№ҖеҪүз’җг„Ұж§ёеҜ°е Ҙеҷёз‘•дҪәж®‘йҠҶеӮҡж№Ә -4жҺіC йҺҙж ЁжҙҝжөЈеәўдҝҜжҗҙпёҝз¬…й”ӣеұҪеҪІжө гғҰжЁүй’ҒжҘҖеҷәзҒҸжҲқдә•йҗўзҶәеўҝйҗЁеӢӯж•“й—ҖиЈӨвӮ¬еӮҡоҮ®жөңеәЁжҡұйҸҲзҶ·еҒҚзҖӣж©ҲзҙқеҜӨйёҝоҶ…жқ©ж¶ңо”‘йҗӘзҶәв”–зҒҸдҪҪо—ҠйҚҡеәқз№ҡйҺёдҪёе–ҺйҚҗжұҮвӮ¬?",
          "text_id": "content.chapter.09-vacuum-properties.page.page1.block.3.text"
        },
        {
          "type": "notice_box",
          "title": "NOTICE",
          "text": "йҗӘзҶәв”–йҚ–е‘°о—Ҡж¶“е¶Ҳе…ҳжө пҪҶжөӣйҚҗз–ҜжЈҢйҺҙж §е–ҺйҚҗжұҮвӮ¬еӮҷжҚўжөЈжӣўжё¶з‘•дҪёе–Һй’ҳеҝ•ж®‘йҸ„ж’№еҺ«жӨӢзҶ·жҗ§йҚҰг„§ж№Ўз»Ңе“„еҜҳз‘Ғе‘ӯжӮ—жө е¶…з№ҖжӨӨи®із№ҡйҺёдҪёе–Һй’ҳеҝ”еһЁйҚҗеі°е–•йҠҶ?",
          "text_id": "content.chapter.09-vacuum-properties.page.page1.block.4.text",
          "title_id": "content.chapter.09-vacuum-properties.page.page1.block.4.title"
        },
        {
          "type": "sub_title",
          "text": "зҖӣжЁәеҒҚйҺёеӣ§еҙЎ",
          "text_id": "content.chapter.09-vacuum-properties.page.page1.block.5.text"
        },
        {
          "type": "bullet_list",
          "items": [
            {
              "text": "й’„о„ғеҪҚйҚҰг„§ж№Ўз»Ңе“„еҜҳз‘Ғе‘ӯеў й—ҮвӮ¬з‘•дҪёеҺӣйҗ’оҲӣжҢүйҠҶеӮҡзҡўй’„о„ғеҪҚйҸҖжғ§еҸҶеЁҢе‘ҠжҢүж¶“о… еҸңйҗ”зҮӮзҙқйҗ’и·әжӮ—еЁҙзЁҝеҸҶйҚҗй”ӢжҢүж¶“о…ЁзҙқйҸҲвӮ¬йҚҡеәЈж•Өе§Јж¶ҳиӮӘйҚҡзЁҝе…ұе§ҳжқ‘еһҺйҚҗе¶Ҳз№ҳзҗӣеІҖж№Ўз»Ңе“„еҜҳз‘Ғе‘«вӮ¬?",
              "text_id": "content.chapter.09-vacuum-properties.page.page1.block.6.item.1"
            },
            {
              "text": "йҚ—дҪёз“§й‘әиҫ©оқ–й’„о„ғеҪҚй”ӣе Је§іеҰһжӢҢеҪҚйҠҶдҪҪеЁҠй‘ҝжәҝвӮ¬дҪёеөҺи№ҮеҶӯеҪҚз»ӣеӨӣзҙҡйҚҰг„ҘеҒҚзҖӣжЁҝз№ғз»Ӣе¬©и…‘жөјж°іеҡңйҗ’иҲөеё“йҸҖзӮ¬зҡөжөЈж“„зҙқйҗ“оҶҫе•ӣйҠҶдҪәж№Ўз»Ңе“„зҡқз‘Ғе‘ӯжӮ—еҜӨйёҝоҶ…зҖӣжЁ»ж–ҒйҚҰг„Ҙе•әз» йҒҚеҷ·йҠҶ?",
              "text_id": "content.chapter.09-vacuum-properties.page.page1.block.6.item.2"
            },
            {
              "text": "йҚ’еӣ§з№үйҗӘзҶәв”–йҚҢг„Ҙз“Ёжҫ¶СҶжҢҸйҺҙж ¬ж§•й‘ҝеӣ©з“‘йҗӘзҶ»еј»жӨӢзҶ·жҗ§йҠҶеӮӣеЁҠйҗӘзҶәв”–йҚҡеәқзҙ°жөңС…ж•“йҸҲеӨҠоҶҠйҗ—в•„е·қй”ӣеІ„о—Өйҗўг„Өзҙ°иӨ°еҚһжҗ·йҚӢгғҘжӮҚйҠҶ?",
              "text_id": "content.chapter.09-vacuum-properties.page.page1.block.6.item.3"
            }
          ]
        }
